# ═══════════════════════════════════════════════════════════════════
#  DUMUZI Luxury Chocolates — Complete .env Template
#
#  FOR RENDER DEPLOYMENT:
#    Set all these as Environment Variables in your Render dashboard
#    (Settings → Environment → Add Environment Variable)
#
#  FOR LOCAL DEV:
#    Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════


# ── SERVER ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
# Render sets this automatically — no need to add manually on Render


# ── POSTGRESQL DATABASE (Render) ────────────────────────────────────
# Render gives you this URL automatically when you create a PostgreSQL database.
# It looks like: postgresql://user:password@host:5432/dbname
#
# In Render Dashboard:
#   1. Go to your Web Service → Environment tab
#   2. You'll see DATABASE_URL already added (if you linked a Render DB)
#   OR copy it from: your PostgreSQL service → Info → Internal Database URL
#
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME


# ── ADMIN AUTHENTICATION ────────────────────────────────────────────
# Run locally: node scripts/generateSecrets.js
# Then paste the output here / in Render environment variables
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=PASTE_BCRYPT_HASH_HERE


# ── JWT SECRET ──────────────────────────────────────────────────────
# Run locally: node scripts/generateSecrets.js
# Then paste the output here / in Render environment variables
JWT_SECRET=PASTE_LONG_RANDOM_SECRET_HERE


# ── CLOUDINARY (Image Uploads) ──────────────────────────────────────
# Sign up at cloudinary.com → Dashboard → copy these 3 values
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


# ── RAZORPAY (Payments) ─────────────────────────────────────────────
# Sign up at razorpay.com → Settings → API Keys → Generate Test Key
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX


# ── LOCAL DEV ONLY (MySQL fallback — ignored if DATABASE_URL is set) ─
# Only needed if running locally without Render PostgreSQL
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=dumuzi_local
# DB_USER=root
# DB_PASSWORD=your_local_password
# DB_SSL=false
